{
    "extends": "../tsconfig.json",
    "compilerOptions": {
        "noEmit": false,
        "outDir": "../../.benchmark-dist",
        "module": "commonjs",
        "moduleResolution": "node",
        "target": "es2020",
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "strict": true,
        "baseUrl": "../..",
        "paths": {}
    },
    "include": ["./**/*.ts", "../src/simulation/**/*.ts"],
    "exclude": ["../../node_modules"]
}
