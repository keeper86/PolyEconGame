{$CADDY_DOMAIN} {
    reverse_proxy app:3000 {
        header_up X-Forwarded-Proto https
        transport http {
            response_header_timeout 30s
            read_timeout 30s
        }
    }
}

auth.{$CADDY_DOMAIN} {
    reverse_proxy keycloak:8080 { 
        header_up X-Forwarded-Proto https
        header_up X-Forwarded-Port 443
        header_up X-Real-IP {remote}
    }
}